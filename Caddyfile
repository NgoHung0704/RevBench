# RevBench reverse proxy.
#
# The site address comes from $SITE_ADDRESS (set in .env), defaulting to ":80"
# (plain HTTP — correct for a bare IP, since Let's Encrypt can't cert an IP).
#
# To enable automatic HTTPS: point a domain at this server, then set
#   SITE_ADDRESS=revbench.example.com
# in .env and restart Caddy. Caddy provisions a Let's Encrypt cert on :443 with
# no other change. (For a local CA / staging, set SITE_ADDRESS=https://...)
{$SITE_ADDRESS::80} {
	encode gzip
	reverse_proxy frontend:3000
}

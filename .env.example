# Copy to .env and fill in. NEVER commit .env.

# --- LLM (Phase 3+) — DeepSeek V4, OpenAI-compatible API (docs/DECISIONS.md D3) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
AGENT_DAILY_BUDGET_USD=1

# --- Market data (Phase 1) — pick per docs/DECISIONS.md D1 ---
TIINGO_API_KEY=
FINNHUB_API_KEY=

# --- SEC EDGAR (Phase 1) — SEC requires a descriptive User-Agent with contact ---
EDGAR_USER_AGENT="RevBench student research project your-email@example.com"

# --- News / social (Phase 1, 5) ---
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=revbench-research/0.1

# --- Storage (Phase 6+) ---
DATABASE_URL=postgresql://revbench:revbench@localhost:5432/revbench

# --- Deployment (Phase 8) ---
# Caddy serves plain HTTP on :80 by default (fine for a bare IP). To enable
# automatic HTTPS, point a domain at the server and set it here, then restart:
#   docker compose -f docker-compose.prod.yml up -d caddy
# SITE_ADDRESS=revbench.example.com
